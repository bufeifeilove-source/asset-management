# Required
SILICONFLOW_API_KEY=sk-your-key-here

# Defaults are suitable for your current Tailscale Qdrant deployment.
MEMORY_QDRANT_URL=http://100.81.130.84:6333
MEMORY_QDRANT_API_KEY=
MEMORY_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
MEMORY_VECTOR_SIZE=4096

# hermes or claude_code. CLI can also override with --client.
MEMORY_CLIENT_NAME=claude_code
MEMORY_DEFAULT_SCOPE=private

# Local reliability queue on your computer.
MEMORY_QUEUE_PATH=~/.local/share/memory-system/memory_queue.sqlite3

# Optional but strongly recommended for the web console.
MEMORY_WEB_TOKEN=change-this-long-random-token
MEMORY_WEB_CORS_ORIGINS=*
MEMORY_WEB_STATIC_DIR=/workspace/asset-management/frontend/dist
